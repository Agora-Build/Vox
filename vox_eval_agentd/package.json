{
  "name": "vox_eval_agentd",
  "version": "1.0.0",
  "description": "Vox Evaluation Agent Daemon - integrates aeval and voice-agent-tester with Vox API",
  "type": "module",
  "main": "vox-agentd.js",
  "scripts": {
    "build": "esbuild vox-agentd.ts --bundle --platform=node --format=esm --outfile=vox-agentd.js --external:child_process --external:fs --external:os --external:path --external:url --external:http --external:@aws-sdk/client-s3",
    "start": "node vox-agentd.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "keywords": [
    "vox",
    "evaluation",
    "voice-agent",
    "testing"
  ],
  "license": "MIT"
}
